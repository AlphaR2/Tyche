# ────────────────────────────────────────────────────────────────────────────
# Tyche TypeScript test environment template
# Copy this file to .env.test and fill in your values:
#
#   cp tests/ts/.env.test.example tests/ts/.env.test
#
# NEVER commit .env.test — it contains keypair file paths.
# ────────────────────────────────────────────────────────────────────────────

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# HTTP endpoint — paste your Helius (or any other) devnet URL here.
# Helius example: https://devnet.helius-rpc.com/?api-key=<YOUR_KEY>
# Public devnet fallback (slower, rate-limited):
RPC_URL=https://api.devnet.solana.com

# WebSocket endpoint — auto-derived from RPC_URL if not set
# (https:// → wss://, http:// → ws://).
# Helius example: wss://devnet.helius-rpc.com/?api-key=<YOUR_KEY>
# RPC_WS_URL=wss://api.devnet.solana.com

# ── Keypair file paths ────────────────────────────────────────────────────────
# Path to Solana CLI keypair JSON files (64-byte array).
# Generate with: solana-keygen new -o <path> --no-bip39-passphrase

AUTHORITY_KEYPAIR=~/.config/solana/tyche-test-authority.json
BIDDER1_KEYPAIR=~/.config/solana/tyche-test-bidder1.json
BIDDER2_KEYPAIR=~/.config/solana/tyche-test-bidder2.json
CRANK_KEYPAIR=~/.config/solana/tyche-test-crank.json

# ── Static addresses ──────────────────────────────────────────────────────────
TREASURY_ADDRESS=<YOUR_TREASURY_BASE58_ADDRESS>

# ── MagicBlock PER (optional) ────────────────────────────────────────────────
# Set MAGICBLOCK_VALIDATOR=1 to enable tests that use the MagicBlock PER
# (ActivateAuction, PlaceBid). These tests are skipped when absent.
# MAGICBLOCK_VALIDATOR=1

# Devnet MagicBlock validator address.
# MAGICBLOCK_VALIDATOR_ADDRESS=LuzXEV3trGF4jQzpRzZaaTB9TqSwLkB7bpKQCQC7BAg
